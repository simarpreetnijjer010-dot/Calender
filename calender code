import java.util.Scanner;

public class Calendar
{
    public static void main(String[] args)
    {
        new Calendar();
    }

    public Calendar()
    {
        Scanner input = new Scanner(System.in);

        System.out.print("Enter the month: ");
        String month = input.nextLine();

        
        month = month.toLowerCase();


        if (month.equals("september") || month.equals("april") || month.equals("june") || month.equals("november"))
        {
            System.out.println("That month has 30 days.");
        }
        else if (month.equals("february"))
        {
            System.out.println("That month has 28 days.");
        }
        else
        {
            System.out.println("That month has 31 days.");
        }

        System.out.println();
        System.out.print("Enter a number for the day of the week (1-7): ");
        int day = input.nextInt();

        
        if (day == 1)
            System.out.println("Monday");
        else if (day == 2)
            System.out.println("Tuesday");
        else if (day == 3)
            System.out.println("Wednesday");
        else if (day == 4)
            System.out.println("Thursday");
        else if (day == 5)
            System.out.println("Friday");
        else if (day == 6)
            System.out.println("Saturday");
        else if (day == 7)
            System.out.println("Sunday");
        else
            System.out.println("Invalid day number!");

        System.out.println();
        System.out.print("Enter the year: ");
        int year = input.nextInt();

        
        if (year % 4 != 0)
            System.out.println("It is not a leap year.");
        else if (year % 100 != 0)
            System.out.println("It is a leap year.");
        else if (year % 400 != 0)
            System.out.println("It is not a leap year.");
        else
            System.out.println("It is a leap year.");

        input.close();
    }
}

